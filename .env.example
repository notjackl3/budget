# --- Database ---
# The app talks to libSQL/SQLite via the Prisma driver adapter (lib/prisma.ts).
#
# Local dev: a plain on-disk SQLite file (zero setup, survives restarts). NOTE
# the path is resolved relative to the project root (CWD), so it must include
# the prisma/ dir — unlike Prisma's native `file:` resolution.
DATABASE_URL="file:./prisma/dev.db"
# Production (Vercel): a Turso/libSQL database, since Vercel's filesystem is
# read-only and ephemeral. Set these two instead of DATABASE_URL — they win when
# present. Create with the Turso CLI: `turso db create <name>` then
# `turso db show <name> --url` and `turso db tokens create <name>`.
# TURSO_DATABASE_URL="libsql://<db>-<org>.turso.io"
# TURSO_AUTH_TOKEN="<token>"

# --- Auth ---
# The password you'll log in with. Use a strong, unique value in production.
APP_PASSWORD="changeme"
# Secret used to sign the session cookie (min 16 chars). MUST be a long random
# string in production — generate one with: openssl rand -base64 32
# The app refuses to start in production if this still looks like a placeholder
# (contains "change-me", "dev-secret", "please", etc.).
AUTH_SECRET="dev-secret-change-me-please-32chars-min"

# --- App ---
# Default display currency symbol/code (configurable in Settings too).
NEXT_PUBLIC_DEFAULT_CURRENCY="CAD"

# --- Email-alert ingestion (Gmail via Composio) ---
# Lets the app read CIBC transaction-alert emails and ingest them as provisional
# expenses (Settings → Email connection → Connect Gmail, and `npm run poll:email`
# on a schedule). OAuth is brokered by Composio — no Google Cloud project needed.
# Get an API key at https://app.composio.dev (Settings → API Keys).
COMPOSIO_API_KEY=""
# Stable per-app user id Composio keys the connection under (any string).
COMPOSIO_USER_ID="budget-user"
# Optional: pin a specific Gmail auth config (ac_…); blank = the app creates a
# Composio-managed one automatically on first connect.
COMPOSIO_GMAIL_AUTH_CONFIG_ID=""
# Optional: Gmail search that selects the alert emails (default: from:cibc.com).
GMAIL_SEARCH_QUERY="from:cibc.com"
