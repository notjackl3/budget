# --- Database ---
# Default: local SQLite file (zero setup, survives restarts).
DATABASE_URL="file:./dev.db"
# For Postgres (e.g. Vercel + Supabase/Neon), switch the provider in
# prisma/schema.prisma to "postgresql" and use a URL like:
# DATABASE_URL="postgresql://user:pass@host:5432/budget?schema=public"

# --- Auth ---
# The password you'll log in with. Use a strong, unique value in production.
APP_PASSWORD="changeme"
# Secret used to sign the session cookie (min 16 chars). MUST be a long random
# string in production — generate one with: openssl rand -base64 32
# The app refuses to start in production if this still looks like a placeholder
# (contains "change-me", "dev-secret", "please", etc.).
AUTH_SECRET="dev-secret-change-me-please-32chars-min"

# --- App ---
# Default display currency symbol/code (configurable in Settings too).
NEXT_PUBLIC_DEFAULT_CURRENCY="CAD"
